<?xml version="1.0" encoding="utf-8"?>
<!-- In light mode the gradient_bg is not ideal because it uses
     hard-coded dark colors. Replace it with a solid theme reference
     so both modes look clean. Drawables can't reference ?attr colors
     directly, so we use a layer-list with a single solid. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid android:color="@color/bg_dark"/>
</shape>